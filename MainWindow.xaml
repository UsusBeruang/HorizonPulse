<Window x:Class="HorizonPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Horizon Pulse" Height="800" Width="1200"
        Background="#0A0C0F" Foreground="White">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════
             COLOR PALETTE
             ═══════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgBase"        Color="#0A0C0F"/>
        <SolidColorBrush x:Key="BgSurface"     Color="#111418"/>
        <SolidColorBrush x:Key="BgCard"        Color="#181C22"/>
        <SolidColorBrush x:Key="BgCardHover"   Color="#1E242C"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#00E676"/>
        <SolidColorBrush x:Key="AccentAmber"   Color="#FFB300"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#FF3D3D"/>
        <SolidColorBrush x:Key="Border"        Color="#252B35"/>
        <SolidColorBrush x:Key="BorderStrong"  Color="#2E3644"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E8EDF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7A8799"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#414D5E"/>

        <!-- ═══════════════════════════════════════════
             TYPOGRAPHY
             ═══════════════════════════════════════════ -->
        <!-- Label style — muted uppercase tracking -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Consolas"/>
            <Setter Property="FontSize"      Value="10"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondary}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>

        <!-- Value style — large, bright data readout -->
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Consolas"/>
            <Setter Property="FontSize"      Value="20"/>
            <Setter Property="FontWeight"    Value="Bold"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondary}"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             CARD BORDER STYLE
             ═══════════════════════════════════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="16,14"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>

        <!-- ═══════════════════════════════════════════
             DIVIDER LINE
             ═══════════════════════════════════════════ -->
        <Style x:Key="Divider" TargetType="Rectangle">
            <Setter Property="Fill"   Value="{StaticResource Border}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18,14,18,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ╔═══════════════════════════════════════════╗
             ║  HEADER                                   ║
             ╚═══════════════════════════════════════════╝ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Wordmark -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Accent bar -->
                <Rectangle Width="3" Height="26" Fill="{StaticResource AccentGreen}"
                           RadiusX="1.5" RadiusY="1.5" Margin="0,0,10,0"/>

                <TextBlock VerticalAlignment="Center">
                    <Run Text="HORIZON" FontFamily="Segoe UI" FontSize="20" FontWeight="Black"
                         Foreground="{StaticResource TextPrimary}"/>
                    <Run Text=" PULSE" FontFamily="Segoe UI" FontSize="20" FontWeight="Light"
                         Foreground="{StaticResource TextSecondary}"/>
                </TextBlock>

                <!-- Version chip -->
                <Border Background="#0D2B1A" BorderBrush="#1A5C34" BorderThickness="1"
                        CornerRadius="3" Padding="7,2" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="TELEMETRY" FontFamily="Consolas" FontSize="9"
                               Foreground="{StaticResource AccentGreen}"/>
                </Border>
            </StackPanel>

            <!-- Status pill -->
            <Border Grid.Column="1" Background="#0D2B1A" BorderBrush="#1A5C34"
                    BorderThickness="1" CornerRadius="4" Padding="10,5"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <!-- Pulsing dot simulation via solid ellipse -->
                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentGreen}"
                             Margin="0,0,7,0" VerticalAlignment="Center"/>
                    <TextBlock Name="StatusText" Text="CONNECTED" FontFamily="Consolas"
                               FontSize="10" Foreground="{StaticResource AccentGreen}" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Spacer row handled by RowDefinition Height="12" -->

        <!-- ╔═══════════════════════════════════════════╗
             ║  MAIN CONTENT                             ║
             ╚═══════════════════════════════════════════╝ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ┌─────────────────────────────────────┐
                 │  LEFT PANEL — Live Telemetry        │
                 └─────────────────────────────────────┘ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panel label -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Rectangle Width="3" Height="14" Fill="{StaticResource AccentGreen}"
                               RadiusX="1" RadiusY="1" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="LIVE TELEMETRY" Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>

                        <!-- ── VEHICLE STATUS CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="VEHICLE STATUS" Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,14"/>

                                <!-- Speed -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="SPEED" Style="{StaticResource Label}"/>
                                        <TextBlock Name="SpeedKphText" Text="0.0"
                                                   Style="{StaticResource Value}"
                                                   Foreground="{StaticResource AccentGreen}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="km/h"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{StaticResource TextMuted}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}"/>

                                <!-- RPM + Gear side by side with shift cue -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ENGINE RPM" Style="{StaticResource Label}"/>
                                        <TextBlock Name="RpmText" Text="0.0"
                                                   Style="{StaticResource Value}"
                                                   Foreground="{StaticResource AccentAmber}"/>
                                        <!-- Shift up cue indicator -->
                                        <TextBlock Name="ShiftUpCue" Text="⬆ SHIFT UP" 
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="{StaticResource AccentRed}"
                                                   Visibility="Collapsed" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="GEAR" Style="{StaticResource Label}"/>
                                        <TextBlock Name="GearText" Text="–"
                                                   Style="{StaticResource Value}"
                                                   FontSize="28"/>
                                        <!-- Shift down cue indicator -->
                                        <TextBlock Name="ShiftDownCue" Text="⬇ SHIFT DOWN" 
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="{StaticResource AccentGreen}"
                                                   Visibility="Collapsed" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}"/>

                                <!-- Lap -->
                                <StackPanel>
                                    <TextBlock Text="LAP" Style="{StaticResource Label}"/>
                                    <TextBlock Name="LapNumberText" Text="0"
                                               Style="{StaticResource Value}" FontSize="16"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── INPUTS CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="DRIVER INPUTS" Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,14"/>

                                <!-- Throttle -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="THROTTLE" Style="{StaticResource Label}"/>
                                        <!-- Track bar background -->
                                        <Border Height="6" Background="{StaticResource BgSurface}"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                CornerRadius="3" Margin="0,6,0,0">
                                            <Border Name="_ThrottleBar" HorizontalAlignment="Left"
                                                    Width="0" Height="6" Background="{StaticResource AccentGreen}"
                                                    CornerRadius="3"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Name="ThrottleText" Text="0.0%"
                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource AccentGreen}"
                                               VerticalAlignment="Bottom" Margin="12,0,0,0"/>
                                </Grid>

                                <!-- Brake -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="BRAKE" Style="{StaticResource Label}"/>
                                        <Border Height="6" Background="{StaticResource BgSurface}"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                CornerRadius="3" Margin="0,6,0,0">
                                            <Border Name="_BrakeBar" HorizontalAlignment="Left"
                                                    Width="0" Height="6" Background="{StaticResource AccentRed}"
                                                    CornerRadius="3"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Name="BrakeTextInput" Text="0.0%"
                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource AccentRed}"
                                               VerticalAlignment="Bottom" Margin="12,0,0,0"/>
                                </Grid>

                                <!-- Steering -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="STEER" Style="{StaticResource Label}"/>
                                        <Border Height="6" Background="{StaticResource BgSurface}"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                CornerRadius="3" Margin="0,6,0,0">
                                            <!-- Centered neutral bar; full steer = shifts left or right -->
                                            <Border Name="_SteerBar" HorizontalAlignment="Center"
                                                    Width="3" Height="6"
                                                    Background="{StaticResource AccentAmber}"
                                                    CornerRadius="1"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Name="SteerText" Text="0"
                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource AccentAmber}"
                                               VerticalAlignment="Bottom" Margin="12,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── CAR ORIENTATION CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="CAR ORIENTATION" Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,14"/>

                                <!-- Visual Car Representation -->
                                <Border Background="#0D1117" BorderBrush="#252B35" BorderThickness="1"
                                        CornerRadius="4" Height="180" Margin="0,0,0,14">
                                    <Grid>
                                        <!-- Viewport for 3D car model -->
                                        <Viewport3D Name="CarViewport3D" ClipToBounds="True">
                                            <Viewport3D.Camera>
                                                <PerspectiveCamera Position="0,3,6" 
                                                                   LookDirection="0,-0.5,-1" 
                                                                   UpDirection="0,1,0" 
                                                                   FieldOfView="45"/>
                                            </Viewport3D.Camera>
                                            
                                            <!-- Lighting -->
                                            <ModelVisual3D>
                                                <ModelVisual3D.Content>
                                                    <DirectionalLight Color="#FFFFFF" Direction="-1,-1,-1"/>
                                                </ModelVisual3D.Content>
                                            </ModelVisual3D>
                                            <ModelVisual3D>
                                                <ModelVisual3D.Content>
                                                    <AmbientLight Color="#404040"/>
                                                </ModelVisual3D.Content>
                                            </ModelVisual3D>
                                            
                                            <!-- Car Model Container with Transform -->
                                            <ModelVisual3D Name="CarModelContainer">
                                                <ModelVisual3D.Content>
                                                    <Model3DGroup>
                                                        <!-- Car Body (Main Chassis) -->
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <BoxGeometryExtents Center="0,0.4,0" Size="1.8,0.5,0.9"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Material>
                                                                <DiffuseMaterial Brush="#00E676"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        
                                                        <!-- Car Cabin -->
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <BoxGeometryExtents Center="0,0.9,-0.2" Size="1.0,0.4,0.7"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Material>
                                                                <DiffuseMaterial Brush="#181C22"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        
                                                        <!-- Front Wheels -->
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <CylinderGeometry Radius="0.35" Length="0.15" Tessellation="16"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Transform>
                                                                <Transform3DGroup>
                                                                    <RotateTransform3D>
                                                                        <RotateTransform3D.Rotation>
                                                                            <AxisAngleRotation3D Axis="0,0,1" Angle="90"/>
                                                                        </RotateTransform3D.Rotation>
                                                                    </RotateTransform3D>
                                                                    <TranslateTransform3D OffsetX="0.6" OffsetY="0.35" OffsetZ="0.5"/>
                                                                </Transform3DGroup>
                                                            </GeometryModel3D.Transform>
                                                            <GeometryModel3D.Material>
                                                                <DiffuseMaterial Brush="#111111"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <CylinderGeometry Radius="0.35" Length="0.15" Tessellation="16"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Transform>
                                                                <Transform3DGroup>
                                                                    <RotateTransform3D>
                                                                        <RotateTransform3D.Rotation>
                                                                            <AxisAngleRotation3D Axis="0,0,1" Angle="90"/>
                                                                        </RotateTransform3D.Rotation>
                                                                    </RotateTransform3D>
                                                                    <TranslateTransform3D OffsetX="0.6" OffsetY="0.35" OffsetZ="-0.5"/>
                                                                </Transform3DGroup>
                                                            </GeometryModel3D.Transform>
                                                            <GeometryModel3D.Material>
                                                                <DiffuseMaterial Brush="#111111"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        
                                                        <!-- Rear Wheels -->
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <CylinderGeometry Radius="0.35" Length="0.15" Tessellation="16"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Transform>
                                                                <Transform3DGroup>
                                                                    <RotateTransform3D>
                                                                        <RotateTransform3D.Rotation>
                                                                            <AxisAngleRotation3D Axis="0,0,1" Angle="90"/>
                                                                        </RotateTransform3D.Rotation>
                                                                    </RotateTransform3D>
                                                                    <TranslateTransform3D OffsetX="-0.6" OffsetY="0.35" OffsetZ="0.5"/>
                                                                </Transform3DGroup>
                                                            </GeometryModel3D.Transform>
                                                            <GeometryModel3D.Material>
                                                                <DiffuseMaterial Brush="#111111"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <CylinderGeometry Radius="0.35" Length="0.15" Tessellation="16"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Transform>
                                                                <Transform3DGroup>
                                                                    <RotateTransform3D>
                                                                        <RotateTransform3D.Rotation>
                                                                            <AxisAngleRotation3D Axis="0,0,1" Angle="90"/>
                                                                        </RotateTransform3D.Rotation>
                                                                    </RotateTransform3D>
                                                                    <TranslateTransform3D OffsetX="-0.6" OffsetY="0.35" OffsetZ="-0.5"/>
                                                                </Transform3DGroup>
                                                            </GeometryModel3D.Transform>
                                                            <GeometryModel3D.Material>
                                                                <DiffuseMaterial Brush="#111111"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        
                                                        <!-- Headlights -->
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <BoxGeometryExtents Center="0.9,0.4,0.35" Size="0.1,0.15,0.15"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Material>
                                                                <EmissiveMaterial Brush="#FFEB3B"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <BoxGeometryExtents Center="0.9,0.4,-0.35" Size="0.1,0.15,0.15"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Material>
                                                                <EmissiveMaterial Brush="#FFEB3B"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        
                                                        <!-- Taillights -->
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <BoxGeometryExtents Center="-0.9,0.4,0.35" Size="0.1,0.15,0.15"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Material>
                                                                <EmissiveMaterial Brush="#FF3D3D"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                        <GeometryModel3D>
                                                            <GeometryModel3D.Geometry>
                                                                <BoxGeometryExtents Center="-0.9,0.4,-0.35" Size="0.1,0.15,0.15"/>
                                                            </GeometryModel3D.Geometry>
                                                            <GeometryModel3D.Material>
                                                                <EmissiveMaterial Brush="#FF3D3D"/>
                                                            </GeometryModel3D.Material>
                                                        </GeometryModel3D>
                                                    </Model3DGroup>
                                                </ModelVisual3D.Content>
                                                <!-- Car orientation transform - updated from code-behind -->
                                                <ModelVisual3D.Transform>
                                                    <Transform3DGroup Name="CarOrientationTransform">
                                                        <RotateTransform3D Name="YawTransform">
                                                            <RotateTransform3D.Rotation>
                                                                <AxisAngleRotation3D Axis="0,1,0" Angle="0"/>
                                                            </RotateTransform3D.Rotation>
                                                        </RotateTransform3D>
                                                        <RotateTransform3D Name="PitchTransform">
                                                            <RotateTransform3D.Rotation>
                                                                <AxisAngleRotation3D Axis="1,0,0" Angle="0"/>
                                                            </RotateTransform3D.Rotation>
                                                        </RotateTransform3D>
                                                        <RotateTransform3D Name="RollTransform">
                                                            <RotateTransform3D.Rotation>
                                                                <AxisAngleRotation3D Axis="0,0,1" Angle="0"/>
                                                            </RotateTransform3D.Rotation>
                                                        </RotateTransform3D>
                                                    </Transform3DGroup>
                                                </ModelVisual3D.Transform>
                                            </ModelVisual3D>
                                            
                                            <!-- Ground Plane -->
                                            <ModelVisual3D>
                                                <ModelVisual3D.Content>
                                                    <GeometryModel3D>
                                                        <GeometryModel3D.Geometry>
                                                            <MeshGeometry3D Positions="-3,0,-3 3,0,-3 3,0,3 -3,0,3" TriangleIndices="0,1,2 0,2,3"/>
                                                        </GeometryModel3D.Geometry>
                                                        <GeometryModel3D.Material>
                                                            <DiffuseMaterial Brush="#1A1F26"/>
                                                        </GeometryModel3D.Material>
                                                    </GeometryModel3D>
                                                </ModelVisual3D.Content>
                                            </ModelVisual3D>
                                        </Viewport3D>
                                        
                                        <!-- Overlay labels -->
                                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8">
                                            <TextBlock Text="VISUAL ORIENTATION" FontFamily="Consolas" FontSize="9"
                                                       Foreground="#414D5E" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Numerical readout below visual -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="YAW" Style="{StaticResource Label}"/>
                                        <TextBlock Name="YawText" Text="0.0°"
                                                   Style="{StaticResource Value}" FontSize="16"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="PITCH" Style="{StaticResource Label}"/>
                                        <TextBlock Name="PitchText" Text="0.0°"
                                                   Style="{StaticResource Value}" FontSize="16"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel>
                                    <TextBlock Text="ROLL" Style="{StaticResource Label}"/>
                                    <TextBlock Name="RollText" Text="0.0°"
                                               Style="{StaticResource Value}" FontSize="16"
                                               Foreground="{StaticResource AccentAmber}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── TIMING CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="TIMING" Style="{StaticResource SectionHeader}"
                                           Margin="0,0,0,14"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RACE TIME" Style="{StaticResource Label}"/>
                                        <TextBlock Name="RaceTimeText" Text="0.0s"
                                                   Style="{StaticResource Value}" FontSize="16"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="LAP TIME" Style="{StaticResource Label}"/>
                                        <TextBlock Name="CurrentLapTimeText" Text="0.0s"
                                                   Style="{StaticResource Value}"
                                                   FontSize="16"
                                                   Foreground="{StaticResource AccentGreen}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Spacer column -->

            <!-- ┌─────────────────────────────────────┐
                 │  RIGHT PANEL — Telemetry Inspector  │
                 └─────────────────────────────────────┘ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panel label -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Rectangle Width="3" Height="14" Fill="{StaticResource AccentAmber}"
                               RadiusX="1" RadiusY="1" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="TELEMETRY INSPECTOR" Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Inspector surface -->
                <Border Grid.Row="1" Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Padding="14">
                        <StackPanel Name="InspectorPanel">
                            <!-- Dynamic content populated by backend -->
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
