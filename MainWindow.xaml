<Window x:Class="HorizonPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Horizon Pulse" Height="800" Width="1200"
        Background="#0A0C0F" Foreground="White">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════
             COLOR PALETTE
             ═══════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgBase" Color="#0A0C0F" />
        <SolidColorBrush x:Key="BgSurface" Color="#111418" />
        <SolidColorBrush x:Key="BgCard" Color="#181C22" />
        <SolidColorBrush x:Key="BgCardHover" Color="#1E242C" />
        <SolidColorBrush x:Key="AccentGreen" Color="#00E676" />
        <SolidColorBrush x:Key="AccentAmber" Color="#FFB300" />
        <SolidColorBrush x:Key="AccentRed" Color="#FF3D3D" />
        <SolidColorBrush x:Key="Border" Color="#252B35" />
        <SolidColorBrush x:Key="BorderStrong" Color="#2E3644" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EDF5" />
        <SolidColorBrush x:Key="TextSecondary" Color="#7A8799" />
        <SolidColorBrush x:Key="TextMuted" Color="#414D5E" />

        <!-- ═══════════════════════════════════════════
             TYPOGRAPHY
             ═══════════════════════════════════════════ -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        </Style>

        <!-- ═══════════════════════════════════════════
             CARD BORDER STYLE & DIVIDER
             ═══════════════════════════════════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="Divider" TargetType="Rectangle">
            <Setter Property="Fill" Value="{StaticResource Border}" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,10,0,10" />
        </Style>

        <!-- ═══════════════════════════════════════════
             TOGGLE BUTTON STYLE
             ═══════════════════════════════════════════ -->
        <Style x:Key="InspectorToggleStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder" Background="{StaticResource BgBase}" 
                                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                                CornerRadius="4" Padding="10,5" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="INSPECTOR" FontFamily="Consolas" FontSize="10" 
                                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="ToggleState" Text="OFF" FontFamily="Consolas" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource BgSurface}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleState" Property="Text" Value="ON"/>
                                <Setter TargetName="ToggleState" Property="Foreground" Value="{StaticResource AccentAmber}"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18,14,18,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ╔═══════════════════════════════════════════╗
             ║  HEADER                                   ║
             ╚═══════════════════════════════════════════╝ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Wordmark -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Rectangle Width="3" Height="26" Fill="{StaticResource AccentGreen}"
                           RadiusX="1.5" RadiusY="1.5" Margin="0,0,10,0" />

                <TextBlock VerticalAlignment="Center">
                    <Run Text="HORIZON" FontFamily="Segoe UI" FontSize="20" FontWeight="Black"
                         Foreground="{StaticResource TextPrimary}" />
                    <Run Text=" PULSE" FontFamily="Segoe UI" FontSize="20" FontWeight="Light"
                         Foreground="{StaticResource TextSecondary}" />
                </TextBlock>

                <!-- Version chip -->
                <Border Background="#0D2B1A" BorderBrush="#1A5C34" BorderThickness="1"
                        CornerRadius="3" Padding="7,2" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="TELEMETRY" FontFamily="Consolas" FontSize="9"
                               Foreground="{StaticResource AccentGreen}" />
                </Border>
            </StackPanel>

            <!-- Top Right Controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Inspector Toggle -->
                <ToggleButton x:Name="InspectorToggle" Style="{StaticResource InspectorToggleStyle}" 
                              Margin="0,0,12,0" IsChecked="False" Click="InspectorToggle_Click" />

                <!-- Status pill -->
                <Border Background="#0D2B1A" BorderBrush="#1A5C34"
                        BorderThickness="1" CornerRadius="4" Padding="10,5">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentGreen}"
                                 Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Name="StatusText" Text="CONNECTED" FontFamily="Consolas"
                                   FontSize="10" Foreground="{StaticResource AccentGreen}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ╔═══════════════════════════════════════════╗
             ║  MAIN CONTENT                             ║
             ╚═══════════════════════════════════════════╝ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" x:Name="LeftColumn" />
                <ColumnDefinition Width="0" x:Name="SpacerColumn" />
                <ColumnDefinition Width="0" x:Name="InspectorColumn" />
            </Grid.ColumnDefinitions>

            <!-- ┌─────────────────────────────────────┐
                 │  LEFT PANEL — Live Telemetry        │
                 └─────────────────────────────────────┘ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Rectangle Width="3" Height="14" Fill="{StaticResource AccentGreen}"
                               RadiusX="1" RadiusY="1" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="LIVE TELEMETRY" Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>

                        <!-- ── VEHICLE STATUS CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="VEHICLE STATUS" Style="{StaticResource SectionHeader}" Margin="0,0,0,14" />

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="SPEED" Style="{StaticResource Label}" />
                                        <TextBlock Name="SpeedKphText" Text="0.0" Style="{StaticResource Value}" Foreground="{StaticResource AccentGreen}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="km/h" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}" />

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ENGINE RPM" Style="{StaticResource Label}" />
                                        <TextBlock Name="RpmText" Text="0.0" Style="{StaticResource Value}" Foreground="{StaticResource AccentAmber}" />
                                        <TextBlock Name="ShiftUpCue" Text="⬆ SHIFT UP" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource AccentRed}" Visibility="Collapsed" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="GEAR" Style="{StaticResource Label}" />
                                        <TextBlock Name="GearText" Text="–" Style="{StaticResource Value}" FontSize="28" />
                                        <TextBlock Name="ShiftDownCue" Text="⬇ SHIFT DOWN" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource AccentGreen}" Visibility="Collapsed" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}" />

                                <StackPanel>
                                    <TextBlock Text="LAP" Style="{StaticResource Label}" />
                                    <TextBlock Name="LapNumberText" Text="0" Style="{StaticResource Value}" FontSize="16" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── INPUTS CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="DRIVER INPUTS" Style="{StaticResource SectionHeader}" Margin="0,0,0,14" />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="THROTTLE" Style="{StaticResource Label}" />
                                        <Border Height="6" Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Margin="0,6,0,0">
                                            <Border Name="_ThrottleBar" HorizontalAlignment="Left" Width="0" Height="6" Background="{StaticResource AccentGreen}" CornerRadius="3" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Name="ThrottleText" Text="0.0%" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentGreen}" VerticalAlignment="Bottom" Margin="12,0,0,0" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="BRAKE" Style="{StaticResource Label}" />
                                        <Border Height="6" Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Margin="0,6,0,0">
                                            <Border Name="_BrakeBar" HorizontalAlignment="Left" Width="0" Height="6" Background="{StaticResource AccentRed}" CornerRadius="3" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Name="BrakeTextInput" Text="0.0%" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentRed}" VerticalAlignment="Bottom" Margin="12,0,0,0" />
                                </Grid>

                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="STEERING DYNAMICS" Style="{StaticResource Label}" Margin="0,0,0,6" />

                                        <Border Background="#0D1117" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Height="180" Margin="0,0,0,14" ClipToBounds="True">
                                            <Grid>
                                                <Rectangle Height="1" Fill="#1A222D" VerticalAlignment="Center" />
                                                <Rectangle Width="1" Fill="#1A222D" HorizontalAlignment="Center" />

                                                <Grid Width="110" Height="110" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                    <Grid.RenderTransform>
                                                        <RotateTransform x:Name="SteeringWheelTransform" Angle="0" />
                                                    </Grid.RenderTransform>

                                                    <Ellipse Stroke="{StaticResource BorderStrong}" StrokeThickness="10" />
                                                    <Ellipse Stroke="{StaticResource BgSurface}" StrokeThickness="10" StrokeDashArray="2 4" Opacity="0.5" />
                                                    <Ellipse Width="24" Height="24" Fill="{StaticResource BgCard}" Stroke="{StaticResource BorderStrong}" StrokeThickness="2" />
                                                    <Rectangle Width="43" Height="12" Fill="{StaticResource BorderStrong}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0" />
                                                    <Rectangle Width="43" Height="12" Fill="{StaticResource BorderStrong}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                    <Rectangle Width="12" Height="43" Fill="{StaticResource BorderStrong}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4" />
                                                    <Rectangle Width="4" Height="12" Fill="{StaticResource AccentAmber}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-1,0,0" />
                                                    <Ellipse Width="6" Height="6" Fill="{StaticResource AccentRed}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="22,-16,0,0" />
                                                    <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreen}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,-16,22,0" />
                                                </Grid>

                                                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8">
                                                    <TextBlock Text="WHEEL ROTATION" FontFamily="Consolas" FontSize="9" Foreground="#414D5E" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="RAW INPUT" Style="{StaticResource Label}" />
                                                <TextBlock Name="RawSteerText" Text="0" Style="{StaticResource Value}" FontSize="16" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="VISUAL ANGLE" Style="{StaticResource Label}" />
                                                <TextBlock Name="SteerAngleText" Text="0.0°" Style="{StaticResource Value}" FontSize="16" Foreground="{StaticResource AccentAmber}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── TIMING CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="TIMING" Style="{StaticResource SectionHeader}" Margin="0,0,0,14" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RACE TIME" Style="{StaticResource Label}" />
                                        <TextBlock Name="RaceTimeText" Text="0.0s" Style="{StaticResource Value}" FontSize="16" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="LAP TIME" Style="{StaticResource Label}" />
                                        <TextBlock Name="CurrentLapTimeText" Text="0.0s" Style="{StaticResource Value}" FontSize="16" Foreground="{StaticResource AccentGreen}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── AUTOMATION CARD ── -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Rectangle Width="3" Height="14" Fill="{StaticResource AccentAmber}"
                                               RadiusX="1" RadiusY="1" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="AUTOMATION" Style="{StaticResource SectionHeader}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Automation Main Toggle -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="AUTOMATION ENABLED" Style="{StaticResource Label}" />
                                        <TextBlock Text="Assisted driving layer" FontFamily="Consolas" FontSize="9" 
                                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="AutomationEnabledToggle" Grid.Column="1" 
                                                  Width="50" Height="24" 
                                                  Click="AutomationEnabledToggle_Click" />
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}" />

                                <!-- Throttle Assist Toggle -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="THROTTLE ASSIST" Style="{StaticResource Label}" />
                                        <TextBlock Text="Inverse brake mapping" FontFamily="Consolas" FontSize="9" 
                                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ThrottleAssistToggle" Grid.Column="1" 
                                                  Width="50" Height="24" 
                                                  Click="ThrottleAssistToggle_Click" />
                                </Grid>

                                <!-- Throttle Smoothing Slider -->
                                <Grid Margin="0,8,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="THROTTLE SMOOTHING" Style="{StaticResource Label}" />
                                        <Slider x:Name="ThrottleSmoothingSlider" Minimum="0" Maximum="1" Value="0.7"
                                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Margin="0,4,0,0" ValueChanged="ThrottleSmoothingSlider_ValueChanged"/>
                                    </StackPanel>
                                    <TextBlock x:Name="ThrottleSmoothingValueText" Grid.Column="1" 
                                               Text="0.70" FontFamily="Consolas" FontSize="10" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}" />

                                <!-- Steering Assist Toggle -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="STEERING ASSIST" Style="{StaticResource Label}" />
                                        <TextBlock Text="±5° random correction" FontFamily="Consolas" FontSize="9" 
                                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="SteeringAssistToggle" Grid.Column="1" 
                                                  Width="50" Height="24" 
                                                  Click="SteeringAssistToggle_Click" />
                                </Grid>

                                <!-- Steering Randomness Slider -->
                                <Grid Margin="0,8,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RANDOMNESS" Style="{StaticResource Label}" />
                                        <Slider x:Name="SteeringRandomnessSlider" Minimum="0" Maximum="1" Value="0.3"
                                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                Margin="0,4,0,0" ValueChanged="SteeringRandomnessSlider_ValueChanged"/>
                                    </StackPanel>
                                    <TextBlock x:Name="SteeringRandomnessValueText" Grid.Column="1" 
                                               Text="0.30" FontFamily="Consolas" FontSize="10" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}" />

                                <!-- Controller Status -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="VIGEM CONTROLLER" Style="{StaticResource Label}" />
                                        <TextBlock x:Name="ControllerStatusText" Text="Disconnected" FontFamily="Consolas" FontSize="9" 
                                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="ControllerConnectButton" Grid.Column="1" 
                                            Content="CONNECT" FontFamily="Consolas" FontSize="9"
                                            Background="{StaticResource BgBase}" 
                                            Foreground="{StaticResource TextSecondary}"
                                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                                            Padding="8,4" Cursor="Hand" Click="ControllerConnectButton_Click"/>
                                </Grid>

                                <Rectangle Style="{StaticResource Divider}" />

                                <!-- Live Values Display -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="VIRTUAL THROTTLE" Style="{StaticResource Label}" />
                                        <TextBlock x:Name="VirtualThrottleText" Text="0%" Style="{StaticResource Value}" 
                                                   FontSize="16" Foreground="{StaticResource AccentGreen}" />
                                        <Border Height="4" Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                                                BorderThickness="1" CornerRadius="2" Margin="0,4,0,0">
                                            <Border x:Name="VirtualThrottleBar" HorizontalAlignment="Left" Width="0" 
                                                    Height="4" Background="{StaticResource AccentGreen}" CornerRadius="2" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="BRAKE INPUT" Style="{StaticResource Label}" />
                                        <TextBlock x:Name="AutomationBrakeText" Text="0%" Style="{StaticResource Value}" 
                                                   FontSize="16" Foreground="{StaticResource AccentRed}" />
                                        <Border Height="4" Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                                                BorderThickness="1" CornerRadius="2" Margin="0,4,0,0">
                                            <Border x:Name="AutomationBrakeBar" HorizontalAlignment="Left" Width="0" 
                                                    Height="4" Background="{StaticResource AccentRed}" CornerRadius="2" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="STEERING CORR." Style="{StaticResource Label}" />
                                        <TextBlock x:Name="SteeringCorrectionText" Text="0.0°" Style="{StaticResource Value}" 
                                                   FontSize="16" Foreground="{StaticResource AccentAmber}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ┌─────────────────────────────────────┐
                 │  RIGHT PANEL — Telemetry Inspector  │
                 └─────────────────────────────────────┘ -->
            <Grid Grid.Column="2" x:Name="InspectorContainer" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Rectangle Width="3" Height="14" Fill="{StaticResource AccentAmber}"
                               RadiusX="1" RadiusY="1" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="TELEMETRY INSPECTOR" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Padding="14">
                        <StackPanel Name="InspectorPanel">
                            <!-- Dynamic content populated by backend -->
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>